[sub_resource type="Resource" id="Resource_33t4b"]
script = ExtResource("1_pflqy")
Name = "Shoreline road"
Desc = "Already opposing forces are responding to our attacks on this island, however will their response be smooth? Our naval infantrymen have already snuck up in the island and this road not far away from them is an artery to slow down our advances. Disrupt this road by blowing up some enemy trucks!"
Type = 1
InMapPosition = Vector2i(12, 18)
MapPath = "uid://b2y0lmy1aoqxs"
metadata/_custom_type_script = "uid://dj5l06h3bhoe2"

[sub_resource type="Resource" id="Resource_pflqy"]
script = ExtResource("1_pflqy")
Name = "Entrenched hills"
Desc = "Turns out there already are fortifications on the main island, but that section was seemingly hastily dug out, but unbeknowst to them, our logistics teams already brought in heavy weapons to face them off. This spot has serveral MG nests that can bring trouble to our troops, blow them apart!"
Order = 1
InMapPosition = Vector2i(9, 14)
MapPath = "uid://deefn1vyiv3v8"
metadata/_custom_type_script = "uid://dj5l06h3bhoe2"

[sub_resource type="Resource" id="Resource_l0w2v"]
script = ExtResource("1_pflqy")
Name = "Some outpost"
Desc = "This outpost may be the most painful for us all, for opponent has thoroughly planned to fight on this outpost, but for what? Is this some last ditch effort to stall us to compensate for the fact that not everyone has withdrawn from this outpost? Either way who leads this defense is either genius who will shock us, is overly confident, therefore foolish, or worse, no choice but to act now. We have to destroy devices that are being used now, everyone else will take care of the rest."
Order = 2
Type = 6
InMapPosition = Vector2i(14, 9)
MapPath = "uid://bhr6w3pni58io"
metadata/_custom_type_script = "uid://dj5l06h3bhoe2"

[sub_resource type="Resource" id="Resource_btbr6"]
script = ExtResource("1_pflqy")
Name = "Plains"
Desc = "Heaviest and the best weapons have been brought to this island still not entirely under our control. Those fields are broad and so are the defenses that remain, still our heaviest weapons will be brought to flatten said defenses smaller teams to take entirety of the island."
Order = 3
Type = 2
InMapPosition = Vector2i(18, 7)
MapPath = "uid://lf31vlpwba3t"
metadata/_custom_type_script = "uid://dj5l06h3bhoe2"

[sub_resource type="Resource" id="Resource_asn50"]
script = ExtResource("1_pflqy")
Name = "Not a heaven"
Desc = "This smaller island is not as defended as the main island, still the danger lies in mountains and teams inside helicopters have been brought to deal with this hidden depo. The altitude of this depo will change many rules, including how shells will land upon a target on an unheavenly height."
Order = 4
Type = 4
InMapPosition = Vector2i(25, 9)
MapPath = "uid://mxh0jswniowf"
metadata/_custom_type_script = "uid://dj5l06h3bhoe2"

